{
  "name": "rsl-shard-tracker",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev -w @rsl/server\" \"npm run dev -w @rsl/web\"",
    "dev:server": "npm run dev -w @rsl/server",
    "dev:web": "npm run dev -w @rsl/web",
    "test": "npm run test -w @rsl/mercy-calc",
    "test:watch": "npm run test:watch -w @rsl/mercy-calc"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  }
}
